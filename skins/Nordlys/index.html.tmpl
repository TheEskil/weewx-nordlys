<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark light" />
    <title>$station.location</title>
    <link rel="icon" href="icon.svg" type="image/svg+xml" />
    <link rel="manifest" href="nordlys.webmanifest" />
    <meta name="theme-color" content="#0b1220" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f6f9fc" media="(prefers-color-scheme: light)" />
    <link rel="stylesheet" href="dist/nordlys.css" />
    #if $nordlys_user_css
    <link rel="stylesheet" href="$nordlys_user_css" />
    #end if
  </head>
  <body>
    ## Thin shell: the search-list extension serializes {meta, config, current}
    ## to JSON; the Nordlys front-end renders everything from it.
    <script id="nordlys-data" type="application/json">$nordlys_json</script>
    <div id="nordlys-app">
      ## Server-rendered fallback: readable without JavaScript, replaced by
      ## the app when it mounts.
      <div class="nl-fallback">
        <h1>$station.location</h1>
        <dl>
          #for $obs_key in $nordlys_current
          #set $entry = $nordlys_current[$obs_key]
          #if $entry['value'] is not None
          <div>
            <dt>$entry['label']</dt>
            <dd>$entry['value'] $entry['unit']</dd>
          </div>
          #end if
          #end for
        </dl>
      </div>
    </div>
    <script type="module" src="dist/nordlys.js"></script>
  </body>
</html>
