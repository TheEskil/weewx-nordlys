<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark light" />
    <title>$nordlys_page.title · $station.location</title>
    <link rel="canonical" href="$nordlys_page.canonical" />
    <meta name="description" content="$nordlys_seo.description" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="$nordlys_seo.site_name" />
    <meta property="og:title" content="$nordlys_seo.title" />
    <meta property="og:description" content="$nordlys_seo.description" />
    #if $nordlys_seo.url
    <meta property="og:url" content="$nordlys_seo.url" />
    #end if
    <meta property="og:image" content="$nordlys_seo.image" />
    <meta property="og:locale" content="$nordlys_seo.locale" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="$nordlys_seo.title" />
    <meta name="twitter:description" content="$nordlys_seo.description" />
    <meta name="twitter:image" content="$nordlys_seo.image" />
    <script type="application/ld+json">$nordlys_jsonld</script>
    <link rel="icon" href="icon.svg" type="image/svg+xml" />
    <link rel="manifest" href="nordlys.webmanifest" />
    <meta name="theme-color" content="#0b1220" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f6f9fc" media="(prefers-color-scheme: light)" />
    <script>
      // Apply the visitor's saved theme (or the skin mode) before first
      // paint so there is no flash of the wrong theme.
      (function () {
        try {
          var c = localStorage.getItem('nordlys-theme');
          var mode = c === 'light' || c === 'dark' ? c : '$nordlys_theme_mode';
          if (mode === 'light' || mode === 'dark')
            document.documentElement.dataset.theme = mode;
        } catch (e) {}
      })();
    </script>
    <link rel="stylesheet" href="dist/nordlys.css" />
    #if $nordlys_user_css
    <link rel="stylesheet" href="$nordlys_user_css" />
    #end if
  </head>
  <body>
    ## One file per configured page (canonical URL); the front-end reads
    ## the filename and activates that page from the shared payload.
    <script id="nordlys-data" type="application/json">$nordlys_json</script>
    <div id="nordlys-app">
      ## Server-rendered fallback: readable without JavaScript.
      <div class="nl-fallback">
        <h1>$station.location</h1>
        <dl>
          #for $obs_key in $nordlys_current
          #set $entry = $nordlys_current[$obs_key]
          #if $entry['value'] is not None
          <div>
            <dt>$entry['label']</dt>
            <dd>$entry['value'] $entry['unit']</dd>
          </div>
          #end if
          #end for
        </dl>
      </div>
    </div>
    <script type="module" src="dist/nordlys.js"></script>
  </body>
</html>
